PORT=3000
BASE_URL=http://localhost:3000
DATA_FILE=./data/app-db.json

WOOCOMMERCE_BASE_URL=https://your-store.example.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_WEBHOOK_SECRET=your_woocommerce_webhook_secret

WASENDER_BASE_URL=https://www.wasenderapi.com/api
WASENDER_API_TOKEN=your_wasender_api_token
WASENDER_WEBHOOK_SECRET=your_wasender_webhook_secret
WASENDER_SIGNATURE_HEADER=x-wasender-signature

DELIVERY_ETA_CASABLANCA=24h
DELIVERY_ETA_OTHER_CITIES=2 to 3 business days
DEFAULT_DELIVERY_CITY_LABEL=Maghrib
CONFIRMATION_MESSAGE_TEMPLATE=Salam {{customerName}}, twsselna b talab dyalk.\nNumiro dyal talab: {{orderId}}\nTalab dyalk: {{orderItemsSummary}}\nTaman l-kolli: {{orderTotal}}\nLmdina: {{deliveryCity}}\nTawsil: {{deliveryEta}}\nLkhlas 3nd l-istilam.\nIla mtaf9 m3a had chi kaml, rdd b 1. Ila ma bqitich bghiti talab, rdd b 2.
INVALID_REPLY_MESSAGE=Afak rdd ghir b 1 bash t2akked talab, wela b 2 ila ma bqitihch.
